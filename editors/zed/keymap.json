[
  {
    "context": "Editor",
    "bindings": {
      "super-alt-f": [
        "buffer_search::Deploy",
        {
          "replace_enabled": false,
        },
      ],
      "super-alt-r": [
        "buffer_search::Deploy",
        {
          "replace_enabled": true,
        },
      ],
      "super-alt-k": "editor::ToggleSoftWrap",
      "super-alt-m": "editor::ToggleMinimap",
      "super-alt-up": "editor::AddSelectionAbove",
      "super-alt-down": "editor::AddSelectionBelow",
      "super-alt-ctrl-up": "editor::MoveLineUp",
      "super-alt-ctrl-down": "editor::MoveLineDown",
    },
  },
  {
    "bindings": {
      "super-alt-n": "workspace::NewFile",
      "super-alt-space": "workspace::ActivateLastPane",
      "super-alt-[": "workspace::ToggleLeftDock",
      "super-alt-]": "workspace::ToggleRightDock",
      "super-alt-\\": "workspace::ToggleBottomDock",
      "super-alt-/": "project_panel::ToggleFocus",
      "super-alt-.": "git_panel::ToggleFocus",
      "super-alt-'": "agent::ToggleFocus",
      "ctrl-alt-super-'": "multi_workspace::ToggleWorkspaceSidebar",
      "super-alt-;": "terminal_panel::ToggleFocus",
      "super-alt-o": "go_to_line::Toggle",
      "super-alt-ctrl-o": "file_finder::Toggle",
      "super-alt-ctrl-f": "workspace::NewSearch",
      "super-alt-ctrl-m": "project_panel::CollapseAllEntries",
      "super-alt-ctrl-;": "workspace::NewTerminal",
      "super-alt-ctrl-.": "zed::OpenSettings",
      "super-alt-ctrl-k": "zed::OpenKeymap",
      "super-alt-ctrl-p": "command_palette::Toggle",
      "super-alt-ctrl-/": "projects::OpenRemote",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "super-alt-left": "pane::ActivatePreviousItem",
      "super-alt-right": "pane::ActivateNextItem",
      "super-alt-ctrl-left": "pane::SwapItemLeft",
      "super-alt-ctrl-right": "pane::SwapItemRight",
      "super-alt-ctrl-[": [
        "workspace::MoveItemToPaneInDirection",
        {
          "direction": "left",
        },
      ],
      "super-alt-ctrl-]": [
        "workspace::MoveItemToPaneInDirection",
        {
          "direction": "right",
        },
      ],
      "super-alt-w": "pane::CloseActiveItem",
      "super-alt-t": "pane::ReopenClosedItem",
      "super-alt-ctrl-w": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false,
        },
      ],
    },
  },
]
